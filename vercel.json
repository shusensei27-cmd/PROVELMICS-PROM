{
  "version": 2,
  "rewrites": [
    { "source": "/api/novels/chapters", "destination": "/api/novels/index.js" },
    { "source": "/api/novels/:id", "destination": "/api/novels/index.js" },
    { "source": "/api/novels", "destination": "/api/novels/index.js" },
    { "source": "/api/comics/chapters", "destination": "/api/comics/index.js" },
    { "source": "/api/comics/:id", "destination": "/api/comics/index.js" },
    { "source": "/api/comics", "destination": "/api/comics/index.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/css/(.*)", "destination": "/public/css/$1" },
    { "source": "/js/(.*)", "destination": "/public/js/$1" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
